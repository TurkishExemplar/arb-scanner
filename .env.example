# Copy to .env and fill in. .env is git-ignored — never commit real secrets.

# --- Kalshi (trading API; reads work without these) ---
KALSHI_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=./kalshi_private.pem

# --- Polymarket (only needed for live CLOB order placement) ---
POLYMARKET_PRIVATE_KEY=

# --- Execution safety (both required for live trading) ---
ENABLE_EXECUTION=        # set to "true" to arm real orders
DRY_RUN=true             # set to "false" to place real orders

# --- Sizing / edge ---
BANKROLL=0               # total capital for position sizing
MAX_POSITION_SIZE=500    # max $ deployed per arb
MIN_EXECUTION_EDGE=5.0   # min net edge % (after fees) to execute

# --- Tuning (optional) ---
POLL_INTERVAL=10
JACCARD_THRESHOLD=0.15
COSINE_THRESHOLD=0.35
MATCH_PROB_THRESHOLD=0.5
